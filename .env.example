# Database - MongoDB
# For local development (requires MongoDB with replica set)
DATABASE_URL="mongodb://localhost:27017/subtaste_auth?replicaSet=rs0"

# For production (MongoDB Atlas - recommended)
# DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/subtaste?retryWrites=true&w=majority"

# NextAuth Configuration
# For local development
NEXTAUTH_URL="http://localhost:3000"

# For production (update with your Vercel domain)
# NEXTAUTH_URL="https://your-domain.vercel.app"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Google OAuth (Required for production)
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED="true"
